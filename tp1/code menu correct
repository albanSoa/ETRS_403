#include <LiquidCrystal.h>

LiquidCrystal lcd(8, 9, 4, 5, 6, 7);

int adc_key_in;
int lcd_key;

#define btnRIGHT 0
#define btnUP 1
#define btnDOWN 2
#define btnLEFT 3
#define btnSELECT 4
#define btnNONE 5

// lecture des boutons
int read_LCD_buttons()
{
  adc_key_in = analogRead(A0);

  if (adc_key_in > 1000) return btnNONE;

  if (adc_key_in < 60) return btnRIGHT;
  if (adc_key_in < 200) return btnUP;
  if (adc_key_in < 400) return btnDOWN;
  if (adc_key_in < 600) return btnLEFT;
  if (adc_key_in < 800) return btnSELECT;

  return btnNONE;
}

void setup()
{
  lcd.begin(16, 2);
  lcd.setCursor(0,0);
  lcd.print("Push the buttons");
}

void loop()
{
  lcd.setCursor(9,1);
  lcd.print(millis()/1000);

  lcd.setCursor(0,1);

  lcd_key = read_LCD_buttons();

  switch (lcd_key)
  {
    case btnRIGHT:
      lcd.print("RIGHT ");
      break;

    case btnLEFT:
      lcd.print("LEFT  ");
      break;

    case btnUP:
      lcd.print("UP    ");
      break;

    case btnDOWN:
      lcd.print("DOWN  ");
      break;

    case btnSELECT:
      lcd.print("SELECT");
      break;

    case btnNONE:
      lcd.print("NONE  ");
      break;
  }

  delay(150);
}
