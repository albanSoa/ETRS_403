//Motor 1


#include <LiquidCrystal.h>

LiquidCrystal lcd(8, 9, 4, 5, 6, 7);

int adc_key_in;
int lcd_key;

#define btnRIGHT 0
#define btnUP 1
#define btnDOWN 2
#define btnLEFT 3
#define btnSELECT 4
#define btnNONE 5

const int motorPin1 = 3;
const int motorPin2 = 11;
int speed = 180;
const int analog1 = A1;


int read_LCD_buttons()
{
  adc_key_in = analogRead(A0);

  if (adc_key_in > 1000) return btnNONE;

  if (adc_key_in < 60) return btnRIGHT;
  if (adc_key_in < 200) return btnUP;
  if (adc_key_in < 400) return btnDOWN;
  if (adc_key_in < 600) return btnLEFT;
  if (adc_key_in < 800) return btnSELECT;

  return btnNONE;
}

void setup(){
  //Set pins as outputs
  pinMode(motorPin1, OUTPUT);
  pinMode(motorPin2, OUTPUT);
  Serial.begin(9600);
  lcd.begin(16, 2);
  lcd.setCursor(0,0);
  lcd.print("Push the buttons");
  

}

void loop(){
  //Motor Control A in both directions
  int mot_pot1 = analogRead(analog1);
  //Serial.print("mot_pot1 : ");
  //Serial.print(mot_pot1);
  float tension = (mot_pot1*5.0)/1023.0;
  float speed1 = map(mot_pot1,0,511,179,0);
  float speed2 = map(mot_pot1,512,1023,0,179);
  lcd.setCursor(9,1);
  lcd.print(millis()/1000);

  lcd.setCursor(0,1);

  lcd_key = read_LCD_buttons();



  
  



  
  

  switch (lcd_key)
  {
    case btnRIGHT:
      lcd.print("RIGHT ");
      break;

    case btnLEFT:
      lcd.print("LEFT  ");
      break;

    case btnUP:
      lcd.print("UP    ");
      tension = 4.9;
      mot_pot1 = 1023;
      speed2 = map(mot_pot1,512,1023,0,179);
      analogWrite(motorPin2, speed2);  
      
      break;

    case btnDOWN:
      lcd.print("DOWN  ");
      tension = 0.0;
      mot_pot1 = 0;
      speed1 = map(mot_pot1,0,511,179,0);
      analogWrite(motorPin1, speed1); 
      break;

    case btnSELECT:
      lcd.print("SELECT");
      tension = 2.5;
      analogWrite(motorPin1, 0);
      analogWrite(motorPin2, 0);
      break;

    case btnNONE:
      lcd.print("NONE  ");
      break;
  }


  //float speed1 = (mot_pin1*180)/1024
  if (tension > 2.5){   
      analogWrite(motorPin2, speed2);  
  }
  else if (tension < 2.5){   
      analogWrite(motorPin1, speed1); 
  }
  else{
    analogWrite(motorPin1, 0);
    analogWrite(motorPin2, 0);
  }


  Serial.println(tension);
  
  
}
