# Boucle principale du serveur HTTP
# Accepte les connexions, analyse la route et renvoie la page appropriée
def serve(connection):
    # États initiaux de tous les actionneurs
    led_state = 'OFF'
    motor1    = 'OFF'
    motor2    = 'OFF'
    pico_led.off()
    temperature = 0

    while True:
        # Attente et acceptation d une connexion entrante
        client  = connection.accept()[0]
        request = client.recv(1024)
        request = str(request)

        # Extraction de la route depuis la requête HTTP (ex: "GET /avancer HTTP/1.1")
        try:
            request = request.split()[1]
        except IndexError:
            request = '/'

        # Suppression des paramètres GET pour le routage (ex: "/speed?v=50" → "/speed")
        route = request.split('?')[0]

        # Mise à jour des états selon la route reçue
        if   route == '/lighton':  pico_led.on();  led_state = 'ON'
        elif route == '/lightoff': pico_led.off(); led_state = 'OFF'
        elif route == '/avancer':  motor1 = 'ON';  motor2 = 'OFF'  # Moteur 1 seul
        elif route == '/reculer':  motor2 = 'ON';  motor1 = 'OFF'  # Moteur 2 seul
        elif route == '/stop':     motor1 = 'OFF'; motor2 = 'OFF'  # Arrêt total
        elif route == '/speed':
            # Lecture du paramètre "v" envoyé par le slider AJAX
            try:
                val = int(request.split('v=')[1])
                if   val > 0: motor1 = 'ON';  motor2 = 'OFF'  # Valeur positive → avancer
                elif val < 0: motor2 = 'ON';  motor1 = 'OFF'  # Valeur négative → reculer
                else:         motor1 = 'OFF'; motor2 = 'OFF'  # Zéro → arrêt
            except:
                pass

        # Lecture de la température interne du Pico
        temperature = pico_temp_sensor.temp

        # Envoi de l état complet à l Arduino via I2C
        send_to_arduino(temperature, led_state, motor1, motor2)

        # Sélection et envoi de la page HTML en réponse
        if route == '/telecom' or route in ['/avancer', '/reculer', '/stop', '/lighton', '/lightoff']:
            html = page_telecom(temperature, led_state, motor1, motor2)
        elif route == '/speed':
            # Requête AJAX du slider : réponse minimale sans HTML pour ne pas recharger la page
            client.send('HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\n\r\nOK')
            client.close()
            continue
        else:
            html = page_accueil(temperature)

        client.send(html)
        client.close()

# Point d entrée : connexion Wi-Fi puis démarrage du serveur
# En cas d interruption clavier, redémarre le Pico proprement
try:
    ip = connect()
    connection = open_socket(ip)
    serve(connection)
except KeyboardInterrupt:
    machine.reset()
